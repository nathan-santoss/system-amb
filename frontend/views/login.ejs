<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <%- include('partials/head') %>
</head>

<body class="bg-cinzaFundo h-screen flex items-center justify-center p-4">

    <div class="w-full max-w-md bg-white rounded-2xl shadow-xl overflow-hidden flex flex-col items-center p-8">

        <div class="w-20 h-20 bg-azulEscuro rounded-full flex items-center justify-center mb-6 shadow-md">
            <i data-lucide="shield-plus" class="text-white w-10 h-10"></i>
        </div>
        <h1 class="text-2xl font-bold text-azulEscuro text-center mb-2">Nexa Logos</h1>
        <p class="text-sm text-slate-500 text-center mb-8">Sistema Ambulatorial Integrado</p>

        <form id="loginForm" class="w-full space-y-5">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1" for="email">E-mail Corporativo</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i data-lucide="mail" class="h-5 w-5 text-slate-400"></i>
                    </div>
                    <input type="email" id="email" name="email" required placeholder="enfermeira@nexalogos.com"
                        class="w-full pl-10 pr-4 py-3 rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-azulEscuro focus:border-transparent transition-all">
                </div>
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1" for="senha">Senha</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i data-lucide="lock" class="h-5 w-5 text-slate-400"></i>
                    </div>
                    <input type="password" id="senha" name="senha" required placeholder="••••••••"
                        class="w-full pl-10 pr-4 py-3 rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-azulEscuro focus:border-transparent transition-all">
                </div>
            </div>

            <button type="submit"
                class="w-full bg-vermelhoAlerta hover:bg-red-800 text-white font-bold py-3 px-4 rounded-lg shadow-md transition-all flex items-center justify-center gap-2 mt-4">
                <span>Entrar no Sistema</span>
                <i data-lucide="log-in" class="w-5 h-5"></i>
            </button>
        </form>
    </div>

    <script>
        lucide.createIcons();
    </script>
    <script src="/js/login.js"></script>
</body>

</html>