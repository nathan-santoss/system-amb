<!DOCTYPE html>
<html lang="pt-br">

<head>
    <%- include('partials/head') %>
</head>

<body class="bg-gray-100 flex">
    <%- include('partials/sidebar') %>

        <main class="flex-1 p-8">
            <div class="bg-white p-6 rounded-2xl shadow-sm mb-6 flex justify-between items-center">
                <div>
                    <h1 class="text-2xl font-bold text-azulEscuro flex items-center gap-3">
                        <span id="nome-paciente">Nome do Paciente</span>
                        <button onclick="abrirModalEditar()" class="text-blue-500 hover:text-blue-700 transition-colors"
                            title="Editar Dados">
                            <i data-lucide="pencil" class="w-5 h-5"></i>
                        </button>
                    </h1>
                    <p class="text-gray-600">Setor: <span id="setor-paciente">...</span> | Cargo: <span
                            id="cargo-paciente">...</span></p>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <div class="lg:col-span-2 space-y-6">
                </div>
                <div class="space-y-6">
                </div>
            </div>
        </main>

        <div id="modal-editar-paciente"
            class="fixed inset-0 bg-black/60 hidden items-center justify-center z-50 backdrop-blur-sm">
            <div class="bg-white rounded-2xl p-6 w-full max-w-md shadow-2xl">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-xl font-bold text-azulEscuro flex items-center gap-2">
                        <i data-lucide="user-cog" class="w-6 h-6"></i> Editar Paciente
                    </h2>
                    <button onclick="fecharModalEditar()" class="text-gray-400 hover:text-red-500">
                        <i data-lucide="x" class="w-6 h-6"></i>
                    </button>
                </div>
                <form id="form-editar-paciente" class="space-y-4">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700">Nome Completo</label>
                        <input type="text" id="edit-nome"
                            class="w-full px-4 py-2 border rounded-xl bg-gray-50 focus:ring-2 focus:ring-blue-500 outline-none"
                            required>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-semibold text-gray-700">Setor</label>
                            <input type="text" id="edit-setor"
                                class="w-full px-4 py-2 border rounded-xl bg-gray-50 focus:ring-2 focus:ring-blue-500 outline-none"
                                required>
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700">Cargo</label>
                            <input type="text" id="edit-cargo"
                                class="w-full px-4 py-2 border rounded-xl bg-gray-50 focus:ring-2 focus:ring-blue-500 outline-none"
                                required>
                        </div>
                    </div>
                    <button type="submit"
                        class="w-full bg-azulEscuro text-white font-bold py-3 rounded-xl mt-4 hover:bg-blue-800 transition-all">
                        Guardar Alterações
                    </button>
                </form>
            </div>
        </div>

        <script src="/js/ficha-paciente.js"></script>
        <script>lucide.createIcons();</script>
</body>

</html>