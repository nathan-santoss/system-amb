<!DOCTYPE html>
<html lang="pt-br">

<head>
    <%- include('partials/head') %>
</head>

<body class="bg-gray-100 flex min-h-screen">
    <%- include('partials/sidebar') %>

        <main class="flex-1 p-8 overflow-y-auto w-full">
            <div
                class="bg-white p-6 rounded-2xl shadow-sm mb-6 flex justify-between items-center border-l-4 border-azulEscuro">
                <div>
                    <h1 class="text-2xl font-bold text-azulEscuro flex items-center gap-3">
                        <i data-lucide="user" class="w-6 h-6"></i>
                        <span id="info-nome">Carregando...</span>
                    </h1>
                    <p class="text-gray-600 mt-1 font-medium">
                        <span id="info-matricula" class="mr-4">Matrícula: ...</span>
                        <i data-lucide="map-pin" class="w-4 h-4 inline text-gray-400"></i> Setor: <span id="info-setor"
                            class="mr-4">...</span>
                        <i data-lucide="briefcase" class="w-4 h-4 inline text-gray-400"></i> Cargo: <span
                            id="info-cargo">...</span>
                    </p>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

                <div class="lg:col-span-2 space-y-6">
                    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
                        <h2 class="text-xl font-bold text-slate-800 flex items-center gap-2 mb-6">
                            <i data-lucide="activity" class="w-6 h-6 text-azulEscuro"></i> Registro de Triagem
                        </h2>

                        <form id="formTriagem" class="space-y-4">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-sm font-semibold text-gray-700 mb-1">Pressão
                                        Arterial</label>
                                    <input type="text" id="pressao" placeholder="Ex: 120/80"
                                        class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-azulEscuro outline-none"
                                        required>
                                </div>
                                <div>
                                    <label class="block text-sm font-semibold text-gray-700 mb-1">Temperatura
                                        (°C)</label>
                                    <input type="text" id="temperatura" placeholder="Ex: 36.5"
                                        class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-azulEscuro outline-none"
                                        required>
                                </div>
                            </div>

                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-1">Queixa Principal</label>
                                <textarea id="queixa" rows="3"
                                    class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-azulEscuro outline-none resize-none"
                                    required placeholder="Relato do paciente..."></textarea>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-sm font-semibold text-gray-700 mb-1">Gravidade</label>
                                    <select id="gravidade"
                                        class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-azulEscuro outline-none"
                                        required>
                                        <option value="">Selecione...</option>
                                        <option value="Baixa">Baixa (Verde)</option>
                                        <option value="Média">Média (Amarelo)</option>
                                        <option value="Alta">Alta (Vermelho)</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-sm font-semibold text-gray-700 mb-1">Ação Tomada</label>
                                    <select id="acao"
                                        class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-azulEscuro outline-none"
                                        required>
                                        <option value="">Selecione...</option>
                                        <option value="Medicação no Local">Medicação no Local</option>
                                        <option value="Atestado Emitido">Atestado Emitido</option>
                                        <option value="Encaminhado UPA">Encaminhado UPA/Hospital</option>
                                        <option value="Liberado">Liberado ao Trabalho</option>
                                    </select>
                                </div>
                            </div>

                            <button type="submit"
                                class="w-full bg-azulEscuro hover:bg-blue-800 text-white font-bold py-3.5 rounded-xl shadow-md transition-all flex justify-center items-center gap-2 mt-4">
                                <i data-lucide="check-circle" class="w-5 h-5"></i> Salvar Atendimento
                            </button>
                        </form>
                    </div>
                </div>

                <div class="space-y-6">
                    <div class="bg-red-50 rounded-2xl shadow-sm border border-red-100 p-6">
                        <div class="flex justify-between items-center mb-4">
                            <h3 class="font-bold text-red-800 flex items-center gap-2">
                                <i data-lucide="shield-alert" class="w-5 h-5"></i> Alertas Médicos
                            </h3>
                            <button onclick="abrirModalAlergia()"
                                class="text-sm bg-red-100 hover:bg-red-200 text-red-700 font-semibold py-1.5 px-3 rounded-lg transition-colors flex items-center gap-1">
                                <i data-lucide="plus" class="w-4 h-4"></i> Adicionar
                            </button>
                        </div>
                        <ul id="lista-alergias" class="space-y-2">
                            <li class="text-red-400 flex justify-center py-4"><i data-lucide="loader"
                                    class="animate-spin w-5 h-5"></i></li>
                        </ul>
                    </div>
                </div>

            </div>
        </main>

        <div id="modal-backdrop"
            class="fixed inset-0 bg-black/60 hidden items-center justify-center z-50 backdrop-blur-sm">
            <div class="bg-white rounded-2xl p-6 w-full max-w-md shadow-2xl">
                <div class="flex justify-between items-center mb-4">
                    <h3 class="text-xl font-bold text-red-700 flex items-center gap-2">Nova Alergia</h3>
                    <button onclick="fecharModalAlergia()" class="text-gray-400 hover:text-red-500"><i data-lucide="x"
                            class="w-5 h-5"></i></button>
                </div>
                <form id="formAlergia">
                    <input type="text" id="descricao_alergia" placeholder="Ex: Dipirona, Amendoim..."
                        class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-red-400 mb-4 outline-none"
                        required>
                    <button type="submit"
                        class="w-full bg-red-600 hover:bg-red-700 text-white font-bold py-3 rounded-xl transition-all">Salvar
                        Alergia</button>
                </form>
            </div>
        </div>

        <script src="/js/ficha-paciente.js"></script>
        <script>lucide.createIcons();</script>
</body>

</html>