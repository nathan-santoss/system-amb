<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <%- include('partials/head') %>
</head>

<body class="bg-cinzaFundo flex min-h-screen overflow-hidden text-cinzaTexto">
    <%- include('partials/sidebar') %>

        <main class="flex-1 p-8 overflow-y-auto w-full">
            <div class="mb-8">
                <h1 class="text-3xl font-bold text-slate-800 mb-1">Buscar Paciente</h1>
                <p class="text-slate-500 text-sm">Pesquise por nome, matrícula ou CPF para iniciar o atendimento ou
                    gerenciar cadastros.</p>
            </div>

            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 mb-8">
                <form id="formBusca" class="flex flex-col sm:flex-row gap-4">
                    <div class="flex-1 relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <i data-lucide="search" class="h-5 w-5 text-slate-400"></i>
                        </div>
                        <input type="text" id="inputBusca" placeholder="Digite o termo de busca..."
                            class="w-full pl-12 pr-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-azulEscuro focus:border-transparent transition-all">
                    </div>
                    <button type="submit"
                        class="bg-azulEscuro hover:bg-blue-800 text-white font-bold py-3 px-8 rounded-xl shadow-md transition-all flex items-center justify-center gap-2">
                        Buscar
                    </button>
                </form>
            </div>

            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse min-w-[600px]">
                        <thead>
                            <tr
                                class="bg-slate-50 border-b border-slate-100 text-slate-500 text-sm uppercase tracking-wider">
                                <th class="py-4 px-6 font-semibold">Matrícula</th>
                                <th class="py-4 px-6 font-semibold">Nome do Funcionário</th>
                                <th class="py-4 px-6 font-semibold">Cargo / Setor</th>
                                <th class="py-4 px-6 font-semibold text-center">Ações</th>
                            </tr>
                        </thead>
                        <tbody id="tabelaPacientes" class="divide-y divide-slate-100">
                            <tr>
                                <td colspan="4" class="py-12 text-center text-slate-400">
                                    <i data-lucide="users" class="w-12 h-12 mx-auto mb-3 opacity-50"></i>
                                    <p>Utilize a barra acima para procurar um funcionário no sistema.</p>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>

        <div id="modal-editar-paciente"
            class="fixed inset-0 bg-black/60 hidden items-center justify-center z-50 backdrop-blur-sm">
            <div class="bg-white rounded-2xl p-6 w-full max-w-md shadow-2xl">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-xl font-bold text-azulEscuro flex items-center gap-2">
                        <i data-lucide="user-cog" class="w-6 h-6"></i> Editar Funcionário
                    </h2>
                    <button onclick="fecharModalEditar()" class="text-gray-400 hover:text-red-500">
                        <i data-lucide="x" class="w-6 h-6"></i>
                    </button>
                </div>
                <form id="form-editar-paciente" class="space-y-4">
                    <input type="hidden" id="edit-matricula">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700">Nome Completo</label>
                        <input type="text" id="edit-nome"
                            class="w-full px-4 py-2 border rounded-xl bg-gray-50 focus:ring-2 focus:ring-blue-500 outline-none"
                            required>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-semibold text-gray-700">Setor</label>
                            <input type="text" id="edit-setor"
                                class="w-full px-4 py-2 border rounded-xl bg-gray-50 focus:ring-2 focus:ring-blue-500 outline-none"
                                required>
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700">Cargo</label>
                            <input type="text" id="edit-cargo"
                                class="w-full px-4 py-2 border rounded-xl bg-gray-50 focus:ring-2 focus:ring-blue-500 outline-none"
                                required>
                        </div>
                    </div>
                    <button type="submit"
                        class="w-full bg-azulEscuro text-white font-bold py-3 rounded-xl mt-4 hover:bg-blue-800 transition-all">
                        Guardar Alterações
                    </button>
                </form>
            </div>
        </div>

        <script>
            lucide.createIcons();
            if (!localStorage.getItem('token')) window.location.href = '/';
            function fazerLogout() { localStorage.removeItem('token'); window.location.href = '/'; }
        </script>
        <script src="/js/consultar-paciente.js"></script>
</body>

</html>