<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <%- include('partials/head') %>
        <title>Dashboard - Sistema Ambulatório</title>
</head>

<body class="bg-cinzaFundo flex min-h-screen overflow-hidden text-cinzaTexto">

    <%- include('partials/sidebar') %>

        <main class="flex-1 p-8 overflow-y-auto">
            <header class="flex justify-between items-center mb-8">
                <div>
                    <h1 class="text-3xl font-bold text-azulEscuro">Painel do Ambulatório</h1>
                    <p class="text-gray-500 mt-1">Resumo das atividades e estatísticas de hoje.</p>
                </div>
                <button onclick="fazerLogout()"
                    class="bg-vermelhoAlerta hover:bg-red-800 text-white px-5 py-2 rounded-lg font-semibold transition-colors shadow-sm">
                    Sair
                </button>
            </header>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                <div
                    class="bg-white p-6 rounded-xl shadow-sm border-l-4 border-azulEscuro flex flex-col justify-between">
                    <h2 class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-2">Atendimentos Hoje</h2>
                    <h3 id="contador-hoje" class="text-4xl font-bold text-azulEscuro">...</h3>
                </div>

                <div
                    class="bg-white p-6 rounded-xl shadow-sm border-l-4 border-vermelhoAlerta flex flex-col justify-between">
                    <h2 class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-2">Grave / Médio / Normal
                    </h2>
                    <h3 class="text-xl font-bold text-vermelhoAlerta">
                        <span id="count-grave">0</span> / <span id="count-medio">0</span> / <span
                            id="count-normal">0</span>
                    </h3>
                </div>

                <div class="bg-azulEscuro hover:bg-blue-800 transition-colors p-6 rounded-xl shadow-sm flex items-center justify-center cursor-pointer"
                    onclick="window.location.href='/consultar-paciente'">
                    <h2 class="text-lg font-bold text-white uppercase tracking-wider text-center">+ Nova Triagem Rápida
                    </h2>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <div class="bg-white p-6 rounded-xl shadow-sm lg:col-span-2">
                    <h3 class="text-xl font-bold text-azulEscuro mb-4">Últimos Atendimentos</h3>
                    <table class="w-full text-sm">
                        <thead class="text-gray-500 border-b">
                            <tr>
                                <th class="pb-2 text-left">Paciente</th>
                                <th class="pb-2">Severidade</th>
                                <th class="pb-2">Data</th>
                            </tr>
                        </thead>
                        <tbody id="lista-ultimos-atendimentos" class="text-gray-700">
                        </tbody>
                    </table>
                </div>

                <div class="bg-white p-6 rounded-xl shadow-sm">
                    <h3 class="text-xl font-bold text-azulEscuro mb-4">Ranking de Setores (Mês)</h3>
                    <div id="lista-setores" class="space-y-3">
                    </div>
                </div>
            </div>
        </main>

        <script>
            function fazerLogout() {
                
                localStorage.removeItem('token');
                window.location.href = '/';
            }

            async function carregarDashboard() {
                const token = localStorage.getItem('token');
                if (!token) { window.location.href = '/login'; return; }

                try {
                    const resposta = await fetch('http://localhost:3000/dashboard-dados', {
                        method: 'GET',
                        headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' }
                    });

                    if (!resposta.ok) throw new Error('Erro ao carregar dados');
                    const dados = await resposta.json();

                    // Atualizar Cards
                    document.getElementById('contador-hoje').innerText = dados.totalHoje;
                    document.getElementById('count-normal').innerText = dados.severidade.normal || 0;
                    document.getElementById('count-medio').innerText = dados.severidade.medio || 0;
                    document.getElementById('count-grave').innerText = dados.severidade.grave || 0;

                    // Atualizar Tabela Últimos Atendimentos
                    const tabela = document.getElementById('lista-ultimos-atendimentos');
                    tabela.innerHTML = dados.ultimos.map(a => `
                        <tr class="border-b">
                            <td class="py-3">${a.nome}</td>
                            <td class="text-center">${a.severidade}</td>
                            <td class="text-center">${a.data}</td>
                        </tr>
                    `).join('');

                    // Atualizar Ranking Setores
                    const setores = document.getElementById('lista-setores');
                    setores.innerHTML = dados.setores.map(s => `
                        <div class="flex justify-between items-center p-2 bg-gray-50 rounded">
                            <span>${s.nome}</span>
                            <span class="font-bold text-azulEscuro">${s.total}</span>
                        </div>
                    `).join('');

                } catch (erro) {
                    console.error("Erro:", erro);
                }
            }

            document.addEventListener('DOMContentLoaded', carregarDashboard);
        </script>
</body>

</html>