<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>
        <%= tituloPagina %> | Sistema de Ambulatório
    </title>

    <link rel="stylesheet" href="/css/base.css">
</head>

<body>

    <header class="cabecalho-principal">
        <h1>Sistema de Ambulatório</h1>
    </header>

    <main class="conteudo-principal">

        <section class="secao-apresentacao">
            <h2>Painel do Ambulatório</h2>
            <p>Controle geral de atendimentos, triagens e funcionários.</p>
        </section>

        <section class="secao-cards-status">
            <div class="card-status">
                <span class="titulo-status">Pendentes</span>
                <strong id="total-pendentes">0</strong>
            </div>

            <div class="card-status">
                <span class="titulo-status">Em Observação</span>
                <strong id="total-observacao">0</strong>
            </div>

            <div class="card-status">
                <span class="titulo-status">Concluídos</span>
                <strong id="total-concluidos">0</strong>
            </div>
        </section>

        <section class="secao-atendimentos-recentes">
            <h2>Fila de Atendimento Atual</h2>
            <div class="tabela-container">
                <table>
                    <thead>
                        <tr>
                            <th>Matrícula</th>
                            <th>Paciente</th>
                            <th>Status</th>
                            <th>Data/Hora</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody id="corpo-tabela-atendimentos">
                        <tr>
                            <td colspan="5" style="text-align: center;">Carregando a fila de atendimentos...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>

    </main>

    <script src="/js/painel.js"></script>
</body>

</html>